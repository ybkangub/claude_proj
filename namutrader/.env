# 나무증권 Open API 인증 정보
# ⚠️ 이 파일을 .env 로 복사한 후 실제 값으로 채우세요
# ⚠️ .env 파일은 절대 git commit 하지 마세요

APP_KEY=your_app_key_here
APP_SECRET=your_app_secret_here
ACCOUNT_NO=your_account_number_here   # 계좌번호 (숫자만)

# 거래 모드: true=페이퍼(모의), false=실거래
PAPER_TRADING=true

# API 엔드포인트 (⚠️ 나무증권 개발자 포털에서 확인 필요)
BASE_URL=https://openapi.namusecurities.com
WS_URL=wss://openapi.namusecurities.com/ws

# 리스크 파라미터
MAX_POSITION_PCT=0.1        # 단일 포지션 최대 비중 (10%)
DAILY_LOSS_LIMIT_PCT=0.02   # 일일 손실 한도 (2%)

# 전략 실행 주기 (초)
RUN_INTERVAL_SECONDS=60

# Telegram 알림 (선택 사항, 미설정 시 비활성화)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# 파일 경로
LOG_FILE=trading.log
ORDERS_CSV=orders.csv
