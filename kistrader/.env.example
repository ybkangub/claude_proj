# 한국투자증권 KIS Open API 인증 정보
# ⚠️ 이 파일을 .env 로 복사한 후 실제 값으로 채우세요
# ⚠️ .env 파일은 절대 git commit 하지 마세요
# 발급처: https://apiportal.koreainvestment.com

APP_KEY=your_kis_app_key_here
APP_SECRET=your_kis_app_secret_here
ACCOUNT_NO=12345678          # 8자리 계좌번호 (숫자만)
ACCOUNT_PRODUCT_CODE=01      # 계좌상품코드 (보통 01)

# 거래 모드: true=모의투자, false=실거래
# BASE_URL과 WS_URL은 이 값에 따라 config.py가 자동 설정합니다
PAPER_TRADING=true

# 리스크 파라미터
MAX_POSITION_PCT=0.1         # 단일 포지션 최대 비중 (10%)
DAILY_LOSS_LIMIT_PCT=0.02    # 일일 손실 한도 (2%)

# 전략 실행 주기 (초)
RUN_INTERVAL_SECONDS=60

# Telegram 알림 (선택 사항, 미설정 시 비활성화)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# 파일 경로
LOG_FILE=trading.log
ORDERS_CSV=orders.csv
